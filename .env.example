# Server settings
NODE_ENV=development

# Logging configuration
# 0 = ERROR, 1 = WARN, 2 = INFO, 3 = HTTP, 4 = DEBUG
LOG_LEVEL=2

# Database connection (provided by Replit)
# DATABASE_URL=postgres://username:password@host:port/database

# Session management
SESSION_SECRET=your-session-secret-at-least-32-chars-long

# Security settings
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_SECURITY_HEADERS=true

# Telegram Bot configuration (if using Telegram integration)
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_WEBAPP_URL=your-webapp-url