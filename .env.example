# =============================================================================
# The Collab Room - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# All required variables must be set before running the application
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Core Application Settings
# -----------------------------------------------------------------------------

# Application environment (development, test, production)
NODE_ENV=development

# Database connection string (PostgreSQL)
# Format: postgres://username:password@host:port/database
# For local development, you can use a local PostgreSQL instance
# For production, use a managed PostgreSQL service (Neon, Supabase, AWS RDS, etc.)
DATABASE_URL=postgres://username:password@localhost:5432/collabroom

# Session secret for securing cookies and sessions
# Must be at least 32 characters - generate with: openssl rand -hex 32
SESSION_SECRET=your-session-secret-at-least-32-characters-long

# -----------------------------------------------------------------------------
# REQUIRED: Telegram Bot Configuration
# -----------------------------------------------------------------------------

# Your Telegram bot token from @BotFather
# Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional: Separate test bot token for development
# Recommended to use a different bot for testing
TELEGRAM_TEST_BOT_TOKEN=your-test-telegram-bot-token

# -----------------------------------------------------------------------------
# REQUIRED: Application URLs
# -----------------------------------------------------------------------------

# Production webapp URL (your deployed domain)
WEBAPP_URL=https://your-production-domain.com

# Development webapp URL (for local testing with Telegram)
WEBAPP_URL_DEV=https://your-dev-domain.com

# -----------------------------------------------------------------------------
# OPTIONAL: Supabase Storage (for company logos)
# -----------------------------------------------------------------------------

# Supabase project URL (if using Supabase for image storage)
# Get this from your Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Storage bucket name (defaults to 'logos' if not set)
SUPABASE_STORAGE_BUCKET=logos

# Frontend environment variables (prefixed with VITE_ for client access)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_STORAGE_BUCKET=logos

# -----------------------------------------------------------------------------
# OPTIONAL: External API Keys
# -----------------------------------------------------------------------------

# Twitter/X RapidAPI key for fetching Twitter data
# Get this from: https://rapidapi.com/
X_RAPIDAPI_KEY=your-rapidapi-key

# -----------------------------------------------------------------------------
# OPTIONAL: Security Settings
# -----------------------------------------------------------------------------

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Enable security headers (recommended: true)
ENABLE_SECURITY_HEADERS=true

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://telegram.org

# -----------------------------------------------------------------------------
# OPTIONAL: Logging Configuration
# -----------------------------------------------------------------------------

# Log level: 0 = ERROR, 1 = WARN, 2 = INFO, 3 = HTTP, 4 = DEBUG
LOG_LEVEL=2

# -----------------------------------------------------------------------------
# OPTIONAL: Replit-specific Settings
# -----------------------------------------------------------------------------

# Replit domains (auto-populated on Replit)
# REPLIT_DOMAINS=your-repl.replit.app

# -----------------------------------------------------------------------------
# DEVELOPMENT ONLY: Debug Settings
# -----------------------------------------------------------------------------

# Allow development fallbacks (NEVER enable in production)
# This allows bypassing authentication for testing
ALLOW_DEV_FALLBACKS=false
