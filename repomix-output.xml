        .update(notification_preferences)
        .set({
          ...prefs,
          updated_at: new Date()
        })
        .where(eq(notification_preferences.id, existingPrefs.id))
        .returning();
      
      console.log(`[updateUserNotificationPreferences] Updated preferences:`, updatedPrefs);
