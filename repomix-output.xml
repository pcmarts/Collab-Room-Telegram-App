                              <RadioGroupItem value={count} id={`userCount-${count}`} />
                              <Label htmlFor={`userCount-${count}`} className="font-normal">
                                {count}
                              </Label>
                            </div>
                          ))}
                        </RadioGroup>
                      </FormItem>
                    )}
                  />
                )}
                
                {watchedValues.discovery_filter_user_followers_enabled && 
                 watchedValues.twitter_followers && (
                  <div className="mt-4 p-3 bg-primary/5 rounded-lg border border-primary/10">
                    <p className="text-sm">
