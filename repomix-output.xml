                    <h3 className="text-base font-medium">Filter by Collaboration Types</h3>
                    <p className="text-sm text-muted-foreground">
                      Only show collaborations matching these types
                    </p>
                  </div>
                  <Switch
                    checked={watchedValues.discovery_filter_collab_types_enabled}
                    onCheckedChange={toggleFilterEnabled}
                    aria-label="Enable collaboration types filter"
                  />
